<Window x:Class="PZPP_Biblioteka.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PZPP_Biblioteka"
        mc:Ignorable="d"
        Title="Biblioteka - Zarządzanie" Height="300" Width="650">
    <Grid Background="#f9f9f9">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal" Margin="20" >
            <Button Content="Zarządzaj Kategoriami"
                    Command="{Binding OpenKategorieWindowCommand}"
                    Width="180" Height="60" Margin="10"
                    Background="LightBlue" FontWeight="Bold"/>

            <Button Content="Zarządzaj Produktami"
                    Command="{Binding OpenProduktyWindowCommand}"
                    Width="180" Height="60" Margin="10"
                    Background="LightGreen" FontWeight="Bold"/>

            <Button Content="Zarządzaj Zamówieniami"
                    Command="{Binding OpenZamowieniaWindowCommand}"
                    Width="180" Height="60" Margin="10"
                    Background="LightYellow" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
