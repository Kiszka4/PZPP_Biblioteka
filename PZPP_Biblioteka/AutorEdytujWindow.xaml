<Window x:Class="PZPP_Biblioteka.AutorEdytujWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edytuj Autora" Height="200" Width="320"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="10" Background="LightYellow">
        <StackPanel>
            <Label Content="Imię"/>
            <TextBox Text="{Binding Imię, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>
            <Label Content="Nazwisko"/>
            <TextBox Text="{Binding Nazwisko, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>
            <Button Content="Zapisz" Command="{Binding ZapiszCommand}" Margin="0,10,0,0"/>
        </StackPanel>
    </Grid>
</Window>
