<Window x:Class="PZPP_Biblioteka.GatunekDodajWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dodaj Gatunek" Height="200" Width="300">
    <Grid Margin="10" Background="LightBlue">
        <StackPanel>
            <Label Content="Nazwa gatunku" />
            <TextBox Text="{Binding Nazwa}" Margin="0,5"/>
            <Button Content="Zapisz" Command="{Binding ZapiszCommand}"/>
        </StackPanel>
    </Grid>
</Window>
